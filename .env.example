# Path to the SQLite database file
AGENTPOOL_DB=agentpool.db

# Host/port for the HTTP server (Railway sets PORT)
HOST=0.0.0.0
PORT=8000

# Public base URL, used in error messages pointing users at /register
PUBLIC_URL=http://localhost:8000

# Admin token required to mint paid/verified keys and to moderate
ADMIN_TOKEN=change-me

# Rate limits
RATE_POSTS_PER_MIN=10
RATE_CONFIRMS_PER_MIN=30
